// This is a Prisma schema file for LOCAL DEVELOPMENT with SQLite
// For production, use the MySQL version in schema.prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id            String    @id @default(cuid())
  name          String
  email         String    @unique
  password      String
  phone         String?
  gender        String?
  avatar        String?
  role          String    @default("PATIENT")
  isSuspended   Boolean   @default(false)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  therapistProfile TherapistProfile?
  patientAppointments  Appointment[] @relation("PatientAppointments")
  therapistAppointments Appointment[] @relation("TherapistAppointments")
  messages      Message[]
  reviews       Review[]
}

model TherapistProfile {
  id               String   @id @default(cuid())
  userId           String   @unique
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  bio              String
  specializations  String
  languages        String   @default("العربية")
  pricePerSession  Int
  yearsExperience  Int      @default(1)
  rating           Float    @default(5.0)
  reviewCount      Int      @default(0)
  isVerified       Boolean  @default(false)
  isAvailable      Boolean  @default(true)
  certificates     String?
  contractUrl      String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

model Appointment {
  id          String            @id @default(cuid())
  patientId   String
  patient     User              @relation("PatientAppointments", fields: [patientId], references: [id])
  therapistId String
  therapist   User              @relation("TherapistAppointments", fields: [therapistId], references: [id])
  scheduledAt DateTime
  duration    Int               @default(50)
  type        String            @default("VIDEO")
  status      String            @default("PENDING")
  price       Int
  roomName    String            @unique
  notes       String?
  paymentScreenshot String?
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  messages    Message[]
  review      Review?
  sessionNote SessionNote?
}

model Message {
  id            String      @id @default(cuid())
  appointmentId String
  appointment   Appointment @relation(fields: [appointmentId], references: [id], onDelete: Cascade)
  senderId      String
  sender        User        @relation(fields: [senderId], references: [id])
  content       String
  fileUrl       String?
  fileName      String?
  createdAt     DateTime    @default(now())
}

model Review {
  id            String      @id @default(cuid())
  appointmentId String      @unique
  appointment   Appointment @relation(fields: [appointmentId], references: [id], onDelete: Cascade)
  patientId     String
  patient       User        @relation(fields: [patientId], references: [id])
  therapistId   String
  rating        Int
  comment       String?
  createdAt     DateTime    @default(now())
}

model SessionNote {
  id            String      @id @default(cuid())
  appointmentId String      @unique
  appointment   Appointment @relation(fields: [appointmentId], references: [id], onDelete: Cascade)
  content       String
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
}

model AdminLog {
  id        String   @id @default(cuid())
  action    String
  details   String?
  createdAt DateTime @default(now())
}
