generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x", "linux-musl", "debian-openssl-3.0.x", "rhel-openssl-1.0.x", "rhel-openssl-1.1.x", "rhel-openssl-3.0.x", "debian-openssl-1.1.x"]
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}


model User {
  id            String    @id @default(cuid())
  name          String
  email         String    @unique
  password      String
  phone         String?
  gender        String?
  avatar        String?
  role          String    @default("PATIENT")
  isSuspended   Boolean   @default(false)
  isOnline      Boolean   @default(false)
  lastActivityAt DateTime  @default(now())
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  therapistProfile TherapistProfile?
  patientAppointments  Appointment[] @relation("PatientAppointments")
  therapistAppointments Appointment[] @relation("TherapistAppointments")
  messages      Message[]
  reviews       Review[]
  sessionNotes  SessionNote[]
  
  specialistShifts SpecialistShiftAssignment[] @relation("SpecialistShifts")
  therapistSlots   AvailableSlot[] @relation("TherapistSlots")
  
  shiftLeadCommissions Commission[] @relation("ShiftLeaderCommissions")
  specialistCommissions Commission[] @relation("SpecialistCommissions")
  onlineStatusLogs OnlineStatusLog[]
}

model TherapistProfile {
  id               String   @id @default(cuid())
  userId           String   @unique
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  bio              String   @db.Text
  specializations  String   @db.Text
  languages        String   @default("العربية")
  pricePerSession  Int
  yearsExperience  Int      @default(1)
  rating           Float    @default(5.0)
  reviewCount      Int      @default(0)
  isVerified       Boolean  @default(false)
  isAvailable      Boolean  @default(true)
  certificates     String?  @db.Text // JSON string: [{ name: String, url: String, uploadedAt: String, status: String }]
  contractUrl      String?  @db.Text
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

model Appointment {
  id          String            @id @default(cuid())
  patientId   String
  patient     User              @relation("PatientAppointments", fields: [patientId], references: [id], onDelete: Cascade)
  therapistId String
  therapist   User              @relation("TherapistAppointments", fields: [therapistId], references: [id], onDelete: Cascade)
  scheduledAt DateTime
  duration    Int               @default(50)
  type        String            @default("VIDEO")
  status      String            @default("PENDING")
  price       Int
  roomName    String            @unique
  notes       String?
  paymentScreenshot String?     @db.Text
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  messages    Message[]
  review      Review?
  sessionNote SessionNote?
  
  // New: Session monitoring
  sessionStatus SessionStatus?
  availableSlot AvailableSlot?
  commissions Commission[]
}

model Message {
  id            String      @id @default(cuid())
  appointmentId String
  appointment   Appointment @relation(fields: [appointmentId], references: [id], onDelete: Cascade)
  senderId      String
  sender        User        @relation(fields: [senderId], references: [id], onDelete: Cascade)
  content       String   @db.Text
  fileUrl       String?     // URL for shared file
  fileName      String?     // Original name of the shared file
  createdAt     DateTime    @default(now())
}

model Review {
  id            String      @id @default(cuid())
  appointmentId String      @unique
  appointment   Appointment @relation(fields: [appointmentId], references: [id], onDelete: Cascade)
  patientId     String
  patient       User        @relation(fields: [patientId], references: [id], onDelete: Cascade)
  therapistId   String
  rating        Int
  comment       String?
  createdAt     DateTime    @default(now())
}

model SessionNote {
  id            String      @id @default(cuid())
  appointmentId String      @unique
  appointment   Appointment @relation(fields: [appointmentId], references: [id], onDelete: Cascade)
  therapistId   String
  therapist     User        @relation(fields: [therapistId], references: [id], onDelete: Cascade)
  notes         String   @db.Text
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
}

model Article {
  id        String   @id @default(cuid())
  title     String
  slug      String   @unique
  content   String   @db.Text
  author    String
  category  String   @default("عام")
  readTime  String   @default("5 دقائق")
  icon      String   @default("📝")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model PromoCode {
  id        String   @id @default(cuid())
  code      String   @unique
  discount  Int      // Percentage, e.g. 15%
  expiresAt DateTime
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
}

model SupportTicket {
  id          String   @id @default(cuid())
  userName    String
  userEmail   String
  subject     String
  message     String   @db.Text
  status      String   @default("OPEN") // OPEN, RESOLVED, CLOSED
  response    String?  @db.Text
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model SystemNotification {
  id        String   @id @default(cuid())
  title     String
  message   String   @db.Text
  target    String   @default("ALL") // ALL, PATIENTS, THERAPISTS
  createdAt DateTime @default(now())
}

// ============================================
// Customer Service Dashboard Models
// ============================================

model Shift {
  id            String   @id @default(cuid())
  name          String   // مثل: "الفترة الصباحية"، "الفترة المسائية"
  startTime     String   // Format: "08:00" (24-hour)
  endTime       String   // Format: "16:00"
  dayOfWeek     String   // "SUNDAY", "MONDAY", ..., "SATURDAY"
  description   String?  @db.Text
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  specialistAssignments SpecialistShiftAssignment[]
}

model SpecialistShiftAssignment {
  id            String   @id @default(cuid())
  shiftId       String
  shift         Shift    @relation(fields: [shiftId], references: [id], onDelete: Cascade)
  therapistId   String
  therapist     User     @relation("SpecialistShifts", fields: [therapistId], references: [id], onDelete: Cascade)
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@unique([shiftId, therapistId])
}

model AvailableSlot {
  id            String   @id @default(cuid())
  therapistId   String
  therapist     User     @relation("TherapistSlots", fields: [therapistId], references: [id], onDelete: Cascade)
  slotStartTime DateTime
  slotEndTime   DateTime
  duration      Int      @default(50) // minutes
  isBooked      Boolean  @default(false)
  appointmentId String?  @unique
  appointment   Appointment? @relation(fields: [appointmentId], references: [id], onDelete: SetNull)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model SessionStatus {
  id              String   @id @default(cuid())
  appointmentId   String   @unique
  appointment     Appointment @relation(fields: [appointmentId], references: [id], onDelete: Cascade)
  
  // Status stages
  status          String   @default("SCHEDULED") // SCHEDULED, PATIENT_JOINED, THERAPIST_JOINED, IN_PROGRESS, COMPLETED, CANCELLED
  patientJoinedAt DateTime?
  therapistJoinedAt DateTime?
  sessionStartedAt DateTime?
  sessionEndedAt  DateTime?
  
  // Metadata
  roomName        String?
  recordingUrl    String?  @db.Text
  notes           String?  @db.Text
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model Commission {
  id String @id @default(cuid())
  
  shiftLeaderId String
  shiftLeader User @relation("ShiftLeaderCommissions", fields: [shiftLeaderId], references: [id], onDelete: Cascade)
  
  specialistId String
  specialist User @relation("SpecialistCommissions", fields: [specialistId], references: [id], onDelete: Cascade)
  
  appointmentId String
  appointment Appointment @relation(fields: [appointmentId], references: [id], onDelete: Cascade)
  
  sessionAmount Int
  shiftLeaderCommissionPercent Float @default(10)
  specialistCommissionPercent Float @default(50)
  
  shiftLeaderEarnings Int
  specialistEarnings Int
  
  isPaid Boolean @default(false)
  paidAt DateTime?
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model OnlineStatusLog {
  id String @id @default(cuid())
  userId String
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  status String
  timestamp DateTime @default(now())
}
